@model IEnumerable<Infrastructure.Models.ViewModels.CartItemViewModel>

<h2 class="text-center mb-4">🛒 Giỏ hàng của bạn 🛒</h2>

<div class="container">
    <form method="post" action="@Url.Action("Checkout", "Cart")">
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-primary text-center">
                    <tr>
                        <th scope="col">Chọn</th>
                        <th scope="col">📚 Tên sách</th>
                        <th scope="col">🔢 Số lượng</th>
                        <th scope="col">🛠️ Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="align-middle">
                            <td class="text-center">
                                <input type="checkbox" name="selectedItems" value="@item.Id" />
                            </td>
                            <td class="text-center">
                                <strong>@item.BookName</strong>
                                <input type="hidden" name="bookId" value="@item.Id" />
                            </td>
                            <td class="text-center">
                                <form method="post" action="@Url.Action("Update", "Cart")" class="d-inline">
                                    <div class="input-group justify-content-center">
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control w-50 text-center" />
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-warning ms-2">Cập nhật</button>
                                    </div>
                                </form>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-danger mx-1">❌ Xóa</a>
                                    <a href="@Url.Action("Add", new { bookId = item.Id })" class="btn btn-success mx-1">➕ Thêm</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-end mt-4">
            <button type="submit" class="btn btn-primary">🛒 Tiến hành thanh toán</button>
        </div>
    </form>
</div>
